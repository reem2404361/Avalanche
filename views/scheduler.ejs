<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Avalanche | Scheduler</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght=300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/scheduler.css">
    <style>
        .error-banner {
            background: rgba(230, 57, 70, 0.12);
            border: 1px solid rgba(230, 57, 70, 0.4);
            color: #e63946;
            border-radius: 10px;
            padding: 12px 18px;
            font-size: 0.88rem;
            font-weight: 600;
            margin-bottom: 20px;
            display: none;
        }
        .time-slot-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin: 20px 0 30px;
        }
        .slot-btn {
            padding: 14px;
            border: 2px solid rgba(13,19,33,0.12);
            border-radius: 12px;
            background: white;
            font-family: 'Manrope', sans-serif;
            font-weight: 700;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s ease;
            color: var(--primary, #0d1321);
        }
        .slot-btn:hover { border-color: var(--primary, #0d1321); background: #f8fafc; }
        .slot-btn.selected {
            background: var(--primary, #0d1321);
            color: white;
            border-color: var(--primary, #0d1321);
        }
        .submit-loading { opacity: 0.6; pointer-events: none; }

        /* Protection Restriction Guard UI Elements */
        .restriction-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(13, 19, 33, 0.95);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            color: white;
            font-family: 'Manrope', sans-serif;
            text-align: center;
            padding: 20px;
        }
        .restriction-card {
            background: #ffffff;
            color: #0d1321;
            padding: 40px;
            border-radius: 24px;
            max-width: 500px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .restriction-card h2 { font-weight: 800; font-size: 1.8rem; margin-bottom: 12px; color: #e63946; }
        .restriction-card p { font-weight: 600; font-size: 0.95rem; opacity: 0.8; margin-bottom: 25px; line-height: 1.5; }
        .restriction-btn {
            background: #3b82f6;
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-block;
        }
        .restriction-btn:hover { background: #2563eb; }
    </style>
</head>
<body>

<% if (typeof isAllowed !== 'undefined' && isAllowed === false) { %>
<div id="lockOverlay" class="restriction-overlay" style="display: flex;">
    <div class="restriction-card">
        <h2>Action Required</h2>
        <p>Please complete your project system metrics profiles inside our hardware capacity computational matrix first.</p>
        <a href="/calculator" class="restriction-btn">Calculate Your Savings First</a>
    </div>
</div>
<% } %>

<div id="cursor"></div>
<div id="cursor-ring"></div>

<aside class="admin-sidebar">
    <div class="sidebar-header">
        <div class="toggle-row">
            <h2>Avalanche</h2>
            <button class="toggle-btn" id="toggle-btn" type="button">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                    <path d="M3 12h18M3 6h18M3 18h18"></path>
                </svg>
            </button>
        </div>
        <p>User Control Panel</p>
    </div>

    <ul>
        <li>
            <button class="side-btn dashboard" type="button" onclick="location.href='/userdash'">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="9"></rect>
                    <rect x="14" y="3" width="7" height="5"></rect>
                    <rect x="14" y="11" width="7" height="9"></rect>
                    <rect x="3" y="15" width="7" height="5"></rect>
                </svg>
                <span class="side-btn-text">Dashboard</span>
            </button>
        </li>
        <li>
            <button class="side-btn orders" type="button" onclick="location.href='/orders/my'">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                <span class="side-btn-text">Order History</span>
            </button>
        </li>
        <li>
            <button class="side-btn catalog" type="button" onclick="location.href='/customercatalog'">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
                <span class="side-btn-text">Catalog</span>
            </button>
        </li>
        <li>
            <button class="side-btn appointments" id="current" type="button" onclick="location.href='/appointments/schedule'">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <span class="side-btn-text">Schedule</span>
            </button>
        </li>
    </ul>

    <div class="side-bottom">
        <hr />
        <button class="side-btn logout" type="button" onclick="location.href='/logout'">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            <span class="side-btn-text">Log Out</span>
        </button>
    </div>
</aside>

<main class="admin-main" id="main-content">

    <nav>
        <div class="nav-left">Avalanche</div>
        <div class="nav-right">
            <a href="#"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path d="M320 64C302.3 64 288 78.3 288 96L288 99.2C215 114 160 178.6 160 256L160 277.7C160 325.8 143.6 372.5 113.6 410.1L103.8 422.3C98.7 428.6 96 436.4 96 444.5C96 464.1 111.9 480 131.5 480L508.4 480C528 480 543.9 464.1 543.9 444.5C543.9 436.4 541.2 428.6 536.1 422.3L526.3 410.1C496.4 372.5 480 325.8 480 277.7L480 256C480 178.6 425 114 352 99.2L352 96C352 78.3 337.7 64 320 64zM258 528C265.1 555.6 290.2 576 320 576C349.8 576 374.9 555.6 382 528L258 528z"/></svg></a>
        </div>
    </nav>

    <div class="content-padding">

        <header class="page-header">
            <div>
                <span class="page-label">APPOINTMENTS</span>
                <h1>Audit Booking</h1>
            </div>
            <div class="step-indicator">
                <div class="step-dot active" id="dot-1"><span>1</span><p>Pick Date</p></div>
                <div class="step-line"></div>
                <div class="step-dot" id="dot-2"><span>2</span><p>Details</p></div>
            </div>
        </header>

        <section id="step-1" class="step-content">
            <div class="calendar-panel">
                <div class="cal-header">
                    <button type="button" onclick="changeMonth(-1)" class="cal-nav-btn">&lt;</button>
                    <h2 id="monthLabel" class="cal-month-label"></h2>
                    <button type="button" onclick="changeMonth(1)" class="cal-nav-btn">&gt;</button>
                </div>
                <div class="cal-weekdays">
                    <span>SUN</span><span>MON</span><span>TUE</span>
                    <span>WED</span><span>THU</span><span>FRI</span><span>SAT</span>
                </div>
                <div id="calendar-days" class="calendar-grid"></div>
                <button type="button" onclick="nextStep()" class="confirm-btn">CONFIRM DATE &gt;</button>
            </div>
        </section>

        <section id="step-2" class="step-content hidden-step">
            <div class="step2-grid">

               <form id="appointmentForm" class="form-panel" action="/appointments" method="POST">

                    <div id="form-error" class="error-banner"></div>

                    <span class="subtitle">CUSTOMER DETAILS</span>
                    <h2 class="form-title">Fill in the details</h2>

                    <input type="hidden" id="hidden-date-input" name="date" value="">
                    <input type="hidden" id="hidden-slot-input" name="timeSlot" value="">

                    <div class="form-row">
                        <div class="form-field">
                            <label>Full Name</label>
                            <input type="text" name="fullName" id="f-name" placeholder="e.g. Mohamed Ali" required>
                        </div>
                        <div class="form-field">
                            <label>Phone</label>
                            <input type="tel" name="phone" id="f-phone" placeholder="01xxxxxxxxx" pattern="01[0-9]{9}" required>
                        </div>
                    </div>
                    
                    <div class="form-row full-width">
                        <div class="form-field">
                            <label>Address</label>
                            <input type="text" name="address" id="f-address" placeholder="e.g. 12 El-Tahrir St, Downtown" required>
                        </div>
                    </div>

                    <div class="form-row full-width">
                        <div class="form-field">
                            <label>Email</label>
                            <input type="email" name="email" id="f-email" placeholder="you@email.com" required>
                        </div>
                    </div>

                    <label style="font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:1px; opacity:0.5; display:block; margin-bottom:10px;">Select Time Slot</label>
                    <div class="time-slot-grid">
                        <button type="button" class="slot-btn" data-slot="09:00 - 12:00" onclick="selectSlot(this)">09:00 - 12:00</button>
                        <button type="button" class="slot-btn" data-slot="12:00 - 15:00" onclick="selectSlot(this)">12:00 - 15:00</button>
                        <button type="button" class="slot-btn" data-slot="15:00 - 18:00" onclick="selectSlot(this)">15:00 - 18:00</button>
                    </div>

                    <div class="form-field" style="margin-bottom:20px;">
                        <label>Notes (optional)</label>
                        <input type="text" name="notes" placeholder="Any special instructions...">
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="confirm-btn" id="submit-btn">BOOK APPOINTMENT &gt;</button>
                        <button type="button" onclick="resetAll()" class="reset-btn">RESET</button>
                    </div>
                </form>

                <div class="summary-card">
                    <span class="subtitle">BOOKING SUMMARY</span>
                    <div class="summary-row">
                        <p>Selected Date</p>
                        <strong id="summary-date">---</strong>
                    </div>
                    <div class="summary-row">
                        <p>Time Slot</p>
                        <strong id="summary-slot">---</strong>
                    </div>
                    <div class="summary-row">
                        <p>Service</p>
                        <strong>Solar Audit</strong>
                    </div>
                    <hr class="summary-divider">
                    <button type="button" onclick="goBack()" class="back-btn">&lt; Change Date</button>
                </div>

            </div>
        </section>

    </div>

    <footer class="sitefooter">
        <p class="footer-left">AVALANCHE &copy; 2026. EMPOWERING SUSTAINABLE GROWTH.</p>
        <div class="footer-right">
            <p>SYSTEM STATUS: ONLINE</p>
            <p>PRIVACY POLICY</p>
            <p>TERMS OF SERVICE</p>
        </div>
    </footer>

</main>

<script src="/js/scheduler.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Safe check for addresses calculated inside local storage
        const savedAddress = localStorage.getItem("calculatedSavingsAddress");
        if (savedAddress) {
            const addressField = document.getElementById("f-address");
            if (addressField) {
                addressField.value = savedAddress;
                const summaryLoc = document.getElementById("summary-location");
                if (summaryLoc) summaryLoc.innerText = savedAddress;
            }
        }
    });
</script>
</body>
</html>