<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Avalanche | Logout</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/Logout.css">
</head>
<body>

<div class="card">
    <!-- Vector Inline SVG Layout Icon -->
    <div class="logout-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
    </div>

    <p class="bye-label">Session Ended</p>
    <h1 class="bye-heading">Goodbye</h1>
    <p class="bye-sub">You have successfully signed out of your secure session. Thank you for choosing clean renewable energy solutions.</p>

    <div class="redirect-wrap">
        <p class="redirect-text">Redirecting to login portal</p>
        <div class="redirect-bar">
            <div class="redirect-fill"></div>
        </div>
    </div>

    <p class="stamp">Avalanche Solar Systems</p>
</div>

<script>
    setTimeout(function() {
        window.location.href = '/login';
    }, 3000);
</script>
</body>
</html>