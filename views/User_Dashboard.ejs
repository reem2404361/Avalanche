<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/userdash.css" />
    <title>Avalanche</title>
  </head>
  <body>
    <div id="cursor"></div>
    <div id="cursor-ring"></div>

    <div class="container">
      <aside class="user-sidebar">
        <div class="sidebar-header">
          <div class="toggle-row">
            <h2>Avalanche</h2>
            <button class="toggle-btn" id="toggle-btn">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <path d="M3 12h18M3 6h18M3 18h18"></path>
              </svg>
            </button>
          </div>
          <p>User Control Panel</p>
        </div>

        <ul>
          <li>
            <button class="side-btn dashboard" id="current">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="9"></rect>
                <rect x="14" y="3" width="7" height="5"></rect>
                <rect x="14" y="11" width="7" height="9"></rect>
                <rect x="3" y="15" width="7" height="5"></rect>
              </svg>
              <span class="side-btn-text on" on>Dashboard</span>
            </button>
          </li>
          <li>
            <button class="side-btn orders" onclick="location.href='/orders/my'">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
              </svg>
              <span class="side-btn-text">Order History</span>
            </button>
          </li>
          <li>
            <button class="side-btn catalog" onclick="location.href = '/customercatalog'">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
              </svg>
              <span class="side-btn-text">Catalog</span>
            </button>
          </li>
          <li>
            <button class="side-btn appointments" onclick="location.href = '/scheduler'">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <span class="side-btn-text">Schedule</span>
            </button>
          </li>
        </ul>

        <div class="side-bottom">
          <hr />
          <button class="side-btn logout" onclick="location.href='/logout'">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            <span class="side-btn-text">Log Out</span>
          </button>
        </div>
      </aside>

      <div class="main-content">

       <div class="page-header">
        <p class="page-label">USER DASHBOARD</p> 
        <h1>Welcome back, <%= user.name.split(' ')[0] %>.</h1> <!-- Display user's first name -->
       </div>

       <div class="cards">

          <div class="status-card">
            <div class="status-header">
              <svg width="24" height="24" viewBox="0 0 1024 1024" class="icon" version="1.1" xmlns="http://www.w3.org/2000/svg">
                <path d="M300 462.4h424.8v48H300v-48zM300 673.6H560v48H300v-48z" fill="currentcolor"/>
                <path d="M818.4 981.6H205.6c-12.8 0-24.8-2.4-36.8-7.2-11.2-4.8-21.6-11.2-29.6-20-8.8-8.8-15.2-18.4-20-29.6-4.8-12-7.2-24-7.2-36.8V250.4c0-12.8 2.4-24.8 7.2-36.8 4.8-11.2 11.2-21.6 20-29.6 8.8-8.8 18.4-15.2 29.6-20 12-4.8 24-7.2 36.8-7.2h92.8v47.2H205.6c-25.6 0-47.2 20.8-47.2 47.2v637.6c0 25.6 20.8 47.2 47.2 47.2h612c25.6 0 47.2-20.8 47.2-47.2V250.4c0-25.6-20.8-47.2-47.2-47.2H725.6v-47.2h92.8c12.8 0 24.8 2.4 36.8 7.2 11.2 4.8 21.6 11.2 29.6 20 8.8 8.8 15.2 18.4 20 29.6 4.8 12 7.2 24 7.2 36.8v637.6c0 12.8-2.4 24.8-7.2 36.8-4.8 11.2-11.2 21.6-20 29.6-8.8 8.8-18.4 15.2-29.6 20-12 5.6-24 8-36.8 8z" fill=""/>
                <path d="M747.2 297.6H276.8V144c0-32.8 26.4-59.2 59.2-59.2h60.8c21.6-43.2 66.4-71.2 116-71.2 49.6 0 94.4 28 116 71.2h60.8c32.8 0 59.2 26.4 59.2 59.2l-1.6 153.6z m-423.2-47.2h376.8V144c0-6.4-5.6-12-12-12H595.2l-5.6-16c-11.2-32.8-42.4-55.2-77.6-55.2-35.2 0-66.4 22.4-77.6 55.2l-5.6 16H335.2c-6.4 0-12 5.6-12 12v106.4z" fill=""/>
              </svg>
            </div>
            <p>Active Type</p>
            <h2>
              <% if (dashType === 'installation') { %>
                Installation
              <% } else if (dashType === 'order') { %>
                Hardware Order
              <% } else { %>
                No Active Orders
              <% } %>
            </h2>
          </div>

          <div class="schedule-card">
            <svg width="24" height="24" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" stroke-width="3" stroke="#000000" fill="none">
              <path d="M36.66,54.45H8.84A2.5,2.5,0,0,1,6.35,52V12.12A2.49,2.49,0,0,1,8.84,9.63H48.68a2.49,2.49,0,0,1,2.49,2.49v22.4"/>
              <line x1="6.35" y1="20.63" x2="51.17" y2="20.63"/>
              <line x1="16.46" y1="9.63" x2="16.46" y2="4.63"/>
              <line x1="40.42" y1="9.63" x2="40.42" y2="4.63"/>
              <circle cx="45.22" cy="45.44" r="12.43"/>
              <polyline points="45.22 36.7 45.22 45.82 49.57 49.16"/>
            </svg>
            <p><%= dashType === 'installation' ? 'Scheduled Installation' : 'Estimated Arrival' %></p>
            <h2>
              <% if (dashType === 'installation' && appointment && appointment.date) { %>
                <%= new Date(appointment.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              <% } else if (dashType === 'order' && order && order.createdAt) { %>
               <%
                const etaStart = new Date(order.createdAt);
                const etaEnd = new Date(order.createdAt);
               etaStart.setDate(etaStart.getDate() + 5);
              etaEnd.setDate(etaEnd.getDate() + 7);
             %>
             <%= etaStart.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %> –
             <%= etaEnd.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              <% } else { %>
                TBD
              <% } %>
            </h2>
          </div>

          <div class="savings-card">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
            <p>Order Total</p>
            <h2>
              <% if (order && order.totalPrice) { %>
                <%= order.totalPrice.toLocaleString('en-EG') %> EGP
              <% } else { %>
                No Active Order
              <% } %>
            </h2>
          </div>

        </div>
       
        <div class="progress-card">
          <div class="progress-header">
            <h3><%= dashType === 'installation' ? 'Installation Progress' : 'Order Progress' %></h3>
            <%
              // define steps based on type
              const steps = dashType === 'installation'
                ? ['Order Placed', 'Assessment', 'Scheduling', 'Installation', 'Activation']
                : ['Order Placed', 'Approved', 'Shipped', 'Delivered'];
              const completedCount = activeStep < 0 ? 0 : activeStep;
            %>
            <span><%= completedCount %> of <%= steps.length %> steps completed</span>
          </div>

          <div class="stepper">
            <div class="track-bg"></div>
            <!-- track fill width = percentage of progress through steps -->
            <div class="track-fill" style="width: calc(<%= activeStep <= 0 ? 0 : (activeStep / (steps.length - 1)) * 100 %>% )"></div>

            <% steps.forEach(function(label, i) {
              // each step gets a state: done (past), active (current), pending (future)
              const state = i < activeStep ? 'done' : i === activeStep ? 'active' : 'pending';
            %>
              <div class="step">
                <div class="node <%= state %>">
                  <% if (state === 'done') { %>
                    <!-- checkmark for completed steps -->
                    <svg fill="currentColor" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path fill-rule="evenodd" d="M1224,312a12,12,0,1,1,3.32-23.526l-1.08,1.788A10,10,0,1,0,1234,300a9.818,9.818,0,0,0-.59-3.353l1.27-2.108A11.992,11.992,0,0,1,1224,312Zm0.92-8.631a0.925,0.925,0,0,1-.22.355,0.889,0.889,0,0,1-.72.259,0.913,0.913,0,0,1-.94-0.655l-3.82-3.818a0.9,0.9,0,0,1,1.27-1.271l3.25,3.251,7.39-10.974a1,1,0,0,1,1.38-.385,1.051,1.051,0,0,1,.36,1.417Z" transform="translate(-1212 -288)"/>
                    </svg>
                  <% } else if (state === 'active') { %>
                    <!-- clock for the current active step -->
                    <svg fill="currentColor" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M15.09814,12.63379,13,11.42285V7a1,1,0,0,0-2,0v5a.99985.99985,0,0,0,.5.86621l2.59814,1.5a1.00016,1.00016,0,1,0,1-1.73242ZM12,2A10,10,0,1,0,22,12,10.01114,10.01114,0,0,0,12,2Zm0,18a8,8,0,1,1,8-8A8.00917,8.00917,0,0,1,12,20Z"/>
                    </svg>
                  <% } else { %>
                    <!-- small dot for pending steps -->
                    <svg fill="currentColor" width="10" height="10" viewBox="0 0 10 10" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="5" cy="5" r="5"/>
                    </svg>
                  <% } %>
                </div>
                <span class="step-label <%= state %>"><%= label %></span>
              </div>
            <% }); %>
          </div>
        </div>

        <div class="bottom-section">
          <div class="left">
            <div class="image-card">
              <img src="/images/user2.jpg" alt="Trees" />
              <div class="image-overlay"></div>
              <div class="image-text">
                <h3>Rooted in Nature, Powered by the sun</h3>
                <p>Every kilowatt-hour generated is one less drawn from the grid.</p>
              </div>
            </div>

            <div class="left-cards">
              <div class="calc-card" onclick="window.location.href = '/calculator'">
                <svg fill="currentColor" width="18" height="18" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                  <path d="M200,20.00781H56a20.02292,20.02292,0,0,0-20,20v176a20.02292,20.02292,0,0,0,20,20H200a20.02292,20.02292,0,0,0,20-20v-176A20.02292,20.02292,0,0,0,200,20.00781Zm-4,192H60v-168H196ZM80,76A12,12,0,0,1,92,64h72a12,12,0,0,1,0,24H92A12,12,0,0,1,80,76Zm88,52a16,16,0,1,1-16-16A16.01833,16.01833,0,0,1,168,128Zm0,48a16,16,0,1,1-16-16A16.01833,16.01833,0,0,1,168,176Zm-48-48a16,16,0,1,1-16-16A16.01833,16.01833,0,0,1,120,128Zm0,48a16,16,0,1,1-16-16A16.01833,16.01833,0,0,1,120,176Z"/>
                </svg>
                <h3>Calculate your savings</h3>
                <div class="action-arrow">
                  <svg height="18" width="18" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
                    <path fill="currentColor" d="M15.563,40.836c0.195,0.195,0.451,0.293,0.707,0.293s0.512-0.098,0.707-0.293l15-15c0.391-0.391,0.391-1.023,0-1.414l-15-15c-0.391-0.391-1.023-0.391-1.414,0s-0.391,1.023,0,1.414l14.293,14.293L15.563,39.422C15.172,39.813,15.172,40.446,15.563,40.836z"/>
                  </svg>
                </div>
              </div>

             
             <% if (dashType === 'installation') { %>
  <div class="cs-card" onclick="location.href='/scheduler'">
    <svg fill="none" width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
      <line x1="16" y1="2" x2="16" y2="6"></line>
      <line x1="8" y1="2" x2="8" y2="6"></line>
      <line x1="3" y1="10" x2="21" y2="10"></line>
    </svg>
    <h3>Reschedule</h3>
    <div class="action-arrow">
      <svg height="18" width="18" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
        <path fill="currentColor" d="M15.563,40.836c0.195,0.195,0.451,0.293,0.707,0.293s0.512-0.098,0.707-0.293l15-15c0.391-0.391,0.391-1.023,0-1.414l-15-15c-0.391-0.391-1.023-0.391-1.414,0s-0.391,1.023,0,1.414l14.293,14.293L15.563,39.422C15.172,39.813,15.172,40.446,15.563,40.836z"/>
      </svg>
    </div>
  </div>
  <div class="cs-card cancel-action-card" onclick="cancelOrder()">
    <svg fill="none" width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="15" y1="9" x2="9" y2="15"></line>
      <line x1="9" y1="9" x2="15" y2="15"></line>
    </svg>
    <h3>Cancel Order</h3>
    <div class="action-arrow">
      <svg height="18" width="18" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
        <path fill="currentColor" d="M15.563,40.836c0.195,0.195,0.451,0.293,0.707,0.293s0.512-0.098,0.707-0.293l15-15c0.391-0.391,0.391-1.023,0-1.414l-15-15c-0.391-0.391-1.023-0.391-1.414,0s-0.391,1.023,0,1.414l14.293,14.293L15.563,39.422C15.172,39.813,15.172,40.446,15.563,40.836z"/>
      </svg>
    </div>
  </div>
<% } else { %>
  <div class="cs-card" onclick="location.href='/customercatalog'">
    <!-- keep original Browse Catalog here as fallback for non-installation users -->
    <svg fill="currentColor" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" fill="none">
      <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
      <line x1="7" y1="7" x2="7.01" y2="7"></line>
    </svg>
    <h3>Browse Catalog</h3>
    <div class="action-arrow">
      <svg height="18" width="18" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
        <path fill="currentColor" d="M15.563,40.836c0.195,0.195,0.451,0.293,0.707,0.293s0.512-0.098,0.707-0.293l15-15c0.391-0.391,0.391-1.023,0-1.414l-15-15c-0.391-0.391-1.023-0.391-1.414,0s-0.391,1.023,0,1.414l14.293,14.293L15.563,39.422C15.172,39.813,15.172,40.446,15.563,40.836z"/>
      </svg>
    </div>
  </div>
<% } %>
            </div>
          </div>

          <div class="image-card">
            <img src="/images/userdash.jpg" alt="Solar panels" />
            <div class="image-overlay"></div>
            <div class="image-text">
              <h3>Sustainable Living</h3>
              <p>Invest once, save for decades. Solar pays back while your energy stays free.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="/js/userdash.js"></script>
  </body>
</html>

