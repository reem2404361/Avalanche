<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : "Avalanche | Admin Control Core" %></title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght=300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashb.css">
    <style>
        .dashboard-grid {
            display: flex;
            flex-direction: column;
            gap: 20px;
            width: 100%;
            font-family: 'Manrope', sans-serif;
            margin-bottom: 40px;
        }
        @media (min-width: 992px) {
            .dashboard-grid { flex-direction: row; }
        }
        .map-column {
            flex: 100%;
            min-width: 0;
            transition: flex 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .info-column {
            flex: 0;
            min-width: 0;
            opacity: 0;
            visibility: hidden;
            transition: flex 0.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease, visibility 0.4s ease;
        }
        .dashboard-grid.card-open .info-column {
            opacity: 1;
            visibility: visible;
        }
        @media (min-width: 992px) {
            .dashboard-grid.card-open .map-column { flex: 2; }
            .dashboard-grid.card-open .info-column { flex: 1; min-width: 320px; }
        }
        #live-map {
            height: 500px;
            width: 100%;
            border-radius: 24px;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.4);
            background: #0d1321;
            z-index: 1;
        }
        .main-display-card {
            background: #0d1321;
            color: #edf2f4;
            border-radius: 24px;
            padding: 25px;
            height: 100%;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-sizing: border-box;
        }
        .data-field {
            margin-bottom: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 10px;
        }
        .data-label {
            display: block;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #ffb703;
            margin-bottom: 4px;
        }
        .data-value { font-size: 0.95rem; font-weight: 600; }
        .map-static-dot { box-shadow: 0 0 12px rgba(255, 183, 3, 0.8); }
        .btn-action-cancel {
            background: #e63946; color: white; border: none; padding: 6px 14px;
            border-radius: 8px; font-family: 'Manrope', sans-serif; font-weight: 700;
            font-size: 0.8rem; cursor: pointer; transition: background 0.2s ease;
        }
        .btn-action-cancel:hover { background: #b32430; }
        .btn-action-approve {
            background: #10b981; color: white; border: none; padding: 6px 14px;
            border-radius: 8px; font-family: 'Manrope', sans-serif; font-weight: 700;
            font-size: 0.8rem; cursor: pointer; transition: background 0.2s ease;
        }
        .btn-action-approve:hover { background: #059669; }
        .txt-cancelled-label { color: #a3a3a3; font-style: italic; font-weight: 600; }
        .status-rejected { color: #e63946; font-weight: 800; font-size: 0.75rem; letter-spacing: 1px; }
        .action-group { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
    </style>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
<div id="cursor"></div>
<div id="cursor-ring"></div>

<aside class="admin-sidebar">
    <div class="sidebar-header">
        <h2 class="sidebar-header-text">Admin Console</h2>
        <p class="sidebar-discreption">Control Panel</p>
        <button class="toggle-btn" id="toggle-btn">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <path d="M3 12h18M3 6h18M3 18h18"></path>
            </svg>
        </button>
    </div>

    <ul>
        <li>
            <button class="side-btn dashboard" id="current" onclick="location.href='/appointments/admin/dashboard'">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="9"></rect>
                    <rect x="14" y="3" width="7" height="5"></rect>
                    <rect x="14" y="11" width="7" height="9"></rect>
                    <rect x="3" y="15" width="7" height="5"></rect>
                </svg>
                <span class="side-btn-text">Dashboard</span>
            </button>
        </li>
        <li>
            <button class="side-btn orders" onclick="location.href='/orders/manage'">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                <span class="side-btn-text">Order Management</span>
            </button>
        </li>
        <li>
            <button class="side-btn catalog" onclick="location.href='/admincatalog'">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
                <span class="side-btn-text">Catalog</span>
            </button>
        </li>
        <li>
            <button class="side-btn appointments" onclick="location.href='/scheduler'">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <span class="side-btn-text">Appointments Calendar</span>
            </button>
        </li>
    </ul>

    <div class="side-bottom">
        <hr />
        <button class="side-btn logout" type="button" onclick="location.href='/logout'">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            <span class="side-btn-text">Log Out</span>
        </button>
    </div>
</aside>

<main class="admin-main" id="main-content">
    <div class="content-padding">

        <header class="page-header">
            <div>
                <span class="page-label">SYSTEM CONTROL</span>
                <h1>Main Dashboard</h1>
            </div>
        </header>

        <section class="metrics-grid">
            <div class="m-card">
                <p>Ongoing Orders</p>
                <h3><%= typeof ongoingOrders !== 'undefined' ? ongoingOrders : '0' %></h3>
            </div>
            <div class="m-card">
                <p>Scheduled Operations</p>
                <h3><%= (typeof appointments !== 'undefined' && appointments) ? appointments.length : 0 %> Booked</h3>
            </div>
            <div class="m-card">
                <p>Active Nodes</p>
                <h3><%= (typeof appointments !== 'undefined' && appointments) ? appointments.length : 0 %> Nodes</h3>
            </div>
        </section>

        <div class="dashboard-grid" id="main-dashboard-wrapper">
            <div class="map-column">
                <section id="region-section" class="map-card">
                    <div id="live-map"></div>
                </section>
            </div>
            <div class="info-column">
                <div class="main-display-card" id="main-page-data-card">
                    <div id="card-active-content">
                        <h3 id="panel-name" style="color: #ffb703; margin-top: 0; margin-bottom: 20px; font-size: 1.4rem;">-</h3>
                        <div class="data-field"><span class="data-label">Tracking Identification</span><div class="data-value" id="panel-id">-</div></div>
                        <div class="data-field"><span class="data-label">Contact Registry</span><div class="data-value" id="panel-phone">-</div></div>
                        <div class="data-field"><span class="data-label">System Gateway Email</span><div class="data-value" id="panel-email">-</div></div>
                        <div class="data-field"><span class="data-label">Hardware Profile Variant</span><div class="data-value" id="panel-hardware">-</div></div>
                        <div class="data-field"><span class="data-label">Activation Lifecycle Date</span><div class="data-value" id="panel-date">-</div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-container" id="appointments-section" style="margin-bottom: 40px;">
            <h3>Live Scheduled Appointments</h3>
            <table class="activity-table">
                <thead>
                    <tr>
                        <th>Client / User</th>
                        <th>Target Date</th>
                        <th>Time Slot Block</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof appointments !== 'undefined' && appointments && appointments.length > 0) { %>
                        <% appointments.forEach(function(app) { %>
                            <tr>
                                <td>
                                    <strong><%= app.user ? app.user.name : app.fullName || 'Unknown User' %></strong><br>
                                    <small style="color: #888;"><%= app.user ? app.user.email : app.email || '' %></small>
                                </td>
                                <td><%= new Date(app.date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                <td><span style="letter-spacing: 0.5px; font-weight:700;"><%= app.timeSlot %></span></td>
                                <td>
                                    <% if (app.status === 'approved') { %>
                                        <span class="status-active">Approved</span>
                                    <% } else if (app.status === 'cancelled') { %>
                                        <span class="status-rejected">Cancelled</span>
                                    <% } else { %>
                                        <span class="status-pending">Pending</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (app.status !== 'cancelled') { %>
                                        <form action="/appointments/<%= app._id %>/cancel" method="POST" style="margin:0;" onsubmit="return confirm('Cancel this appointment?');">
                                            <button type="submit" class="btn-action-cancel">Cancel</button>
                                        </form>
                                    <% } else { %>
                                        <span class="txt-cancelled-label">No Actions</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; color: #aaa; padding: 30px;">No appointments logged yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="table-container" style="margin-bottom: 40px;">
            <h3>Incoming Orders</h3>
            <table class="activity-table">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Delivery Address</th>
                        <th>Total Price</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof orders !== 'undefined' && orders && orders.length > 0) { %>
                        <% orders.forEach(function(order) { %>
                            <tr>
                                <td>
                                    <strong><%= order.user ? order.user.name : (order.shippingDetails ? order.shippingDetails.fullName : 'Unknown') %></strong><br>
                                    <small style="color: #888;"><%= order.user ? order.user.email : (order.shippingDetails ? order.shippingDetails.email : '') %></small>
                                </td>
                                <td><%= order.shippingDetails ? order.shippingDetails.deliveryAddress : 'N/A' %></td>
                                <td><strong>EGP <%= order.totalPrice ? order.totalPrice.toLocaleString() : '0' %></strong></td>
                                <td>
                                    <% if (order.status === 'approved') { %>
                                        <span class="status-active">Approved</span>
                                    <% } else if (order.status === 'rejected') { %>
                                        <span class="status-rejected">Rejected</span>
                                    <% } else { %>
                                        <span class="status-pending">Pending</span>
                                    <% } %>
                                </td>
                                <td><%= new Date(order.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                <td>
                                    <% if (order.status === 'pending') { %>
                                        <div class="action-group">
                                            <form action="/api/orders/<%= order._id %>/status?_method=PATCH" method="POST" style="margin:0;" onsubmit="return confirm('Approve this order?');">
                                                <input type="hidden" name="status" value="approved">
                                                <button type="submit" class="btn-action-approve">Approve</button>
                                            </form>
                                            <form action="/api/orders/<%= order._id %>/status?_method=PATCH" method="POST" style="margin:0;" onsubmit="return confirm('Reject this order?');">
                                                <input type="hidden" name="status" value="rejected">
                                                <button type="submit" class="btn-action-cancel">Reject</button>
                                            </form>
                                        </div>
                                    <% } else { %>
                                        <span class="txt-cancelled-label">No Actions</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align: center; color: #aaa; padding: 30px;">No orders logged yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="table-container">
            <h3>Recent Activity</h3>
            <table class="activity-table">
                <thead>
                    <tr>
                        <th>Client Name</th>
                        <th>Details</th>
                        <th>Node</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof recentActivity !== 'undefined' && recentActivity && recentActivity.length > 0) { %>
                        <% recentActivity.forEach(function(act) { %>
                            <tr>
                                <td><%= act.user %></td>
                                <td><%= act.details %></td>
                                <td>NODE-LOG</td>
                                <td><span class="status-active"><%= act.type %></span></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; color: #aaa; padding: 30px;">No recent activity</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <footer class="sitefooter">
            <p class="footer-left">AVALANCHE &copy; 2026. EMPOWERING SUSTAINABLE GROWTH.</p>
            <div class="footer-right">
                <p>SYSTEM STATUS: ONLINE</p>
                <p>PRIVACY POLICY</p>
                <p>TERMS OF SERVICE</p>
            </div>
        </footer>

    </div>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const egyptBounds = L.latLngBounds(L.latLng(22.0, 24.8), L.latLng(31.6, 36.0));
    const map = L.map('live-map', {
        maxBounds: egyptBounds,
        maxBoundsViscosity: 1.0,
        minZoom: 6,
        maxZoom: 18
    }).setView([26.8206, 30.8025], 6.5);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap contributors',
        bounds: egyptBounds
    }).addTo(map);

    let mapMarkers = {};

    function openPanelAndDisplayData(user) {
        const wrapper = document.getElementById('main-dashboard-wrapper');
        wrapper.classList.add('card-open');
        setTimeout(function() { map.invalidateSize({ animate: true }); }, 100);
        const dateOptions = { year: 'numeric', month: '2-digit', day: '2-digit' };
        const localizedDate = new Date(user.installDate).toLocaleDateString(undefined, dateOptions);
        document.getElementById('panel-name').textContent = user.name;
        document.getElementById('panel-name').style.color = '#ffb703';
        document.getElementById('panel-id').textContent = user._id;
        document.getElementById('panel-phone').textContent = user.phone;
        document.getElementById('panel-email').textContent = user.email;
        document.getElementById('panel-hardware').textContent = user.orderType;
        document.getElementById('panel-date').textContent = localizedDate;
    }

    function renderGlowingDot(user) {
        const marker = L.circleMarker([user.lat, user.lng], {
            radius: 9,
            color: '#ffb703',
            fillColor: '#ffb703',
            fillOpacity: 0.9,
            className: 'map-static-dot'
        }).addTo(map);
        marker.userDataPayload = user;
        marker.on('click', function() {
            openPanelAndDisplayData(user);
            map.setView(marker.getLatLng(), 8, { animate: true, duration: 0.8 });
        });
        mapMarkers[user._id] = marker;
    }

    function loadLiveDatabaseClients() {
        const liveAppointments = <%- typeof appointments !== 'undefined' ? JSON.stringify(appointments) : '[]' %>;
        const liveOrders = <%- typeof orders !== 'undefined' ? JSON.stringify(orders) : '[]' %>;

        const locationCoords = {
            'cairo':      { lat: 30.0444, lng: 31.2357 },
            'alexandria': { lat: 31.2001, lng: 29.9187 },
            'giza':       { lat: 29.9765, lng: 31.1313 },
            'luxor':      { lat: 25.6872, lng: 32.6396 },
            'aswan':      { lat: 24.0889, lng: 32.8998 },
            'hurghada':   { lat: 27.2579, lng: 33.8116 },
            'sharm':      { lat: 27.9158, lng: 34.3299 },
            'mansoura':   { lat: 31.0409, lng: 31.3785 },
            'tanta':      { lat: 30.7865, lng: 31.0004 },
            'suez':       { lat: 29.9668, lng: 32.5498 }
        };

        function getCoordsFromAddress(address) {
            const rawLocation = (address || 'cairo').toLowerCase().trim();
            let matchedCity = 'cairo';
            Object.keys(locationCoords).forEach(function(city) {
                if (rawLocation.includes(city)) matchedCity = city;
            });
            return {
                lat: locationCoords[matchedCity].lat + (Math.random() - 0.5) * 0.04,
                lng: locationCoords[matchedCity].lng + (Math.random() - 0.5) * 0.04
            };
        }

        liveAppointments.forEach(function(app) {
            if (app.status === 'cancelled') return;
            const coords = getCoordsFromAddress(app.address || app.location);
            renderGlowingDot({
                _id: app._id,
                name: app.fullName || (app.user && app.user.name) || 'Client',
                lat: coords.lat, lng: coords.lng,
                phone: app.phone || 'Not Provided',
                email: app.email || (app.user && app.user.email) || 'Not Provided',
                orderType: 'Appointment: ' + app.timeSlot,
                installDate: app.date
            });
        });

        liveOrders.forEach(function(order) {
            if (order.status === 'rejected') return;
            const address = order.shippingDetails ? order.shippingDetails.deliveryAddress : null;
            const coords = getCoordsFromAddress(address || 'cairo');
            renderGlowingDot({
                _id: order._id,
                name: order.user ? order.user.name : (order.shippingDetails ? order.shippingDetails.fullName : 'Order Client'),
                lat: coords.lat, lng: coords.lng,
                phone: order.user ? order.user.phone : (order.shippingDetails ? order.shippingDetails.phone : 'Not Provided'),
                email: order.user ? order.user.email : (order.shippingDetails ? order.shippingDetails.email : 'Not Provided'),
                orderType: 'Order: EGP ' + (order.totalPrice || 0),
                installDate: order.createdAt
            });
        });
    }

    loadLiveDatabaseClients();
</script>
<script src="/js/dashb.js"></script>
</body>
</html>
