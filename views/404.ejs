<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : "Avalanche | 404" %></title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght=300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/404.css">
</head>
<body>
    <div class="error-container">
        <h1 class="error-code">404</h1>
        <div class="error-title">System Out of Bounds</div>
        <p class="error-msg">
            <%= typeof message !== 'undefined' ? message : "The page you requested does not exist on the network grid." %>
        </p>
        <%# Redirect admin to their dashboard, customers to userdash -%>
        <a href="<%= (typeof user !== 'undefined' && user && user.role === 'admin') ? '/appointments/admin/dashboard' : '/userdash' %>"
           class="home-btn">Return to Console</a>
    </div>
</body>
</html>