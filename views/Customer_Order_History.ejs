<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order History</title>
    <link rel="stylesheet" href="/css/Customer_Order_History.css" />
  </head>
  <body>
    <div id="cursor"></div>
    <div id="cursor-ring"></div>

    <aside class="customer-sidebar">
      <div class="sidebar-header">
        <div class="toggle-row">
          <h2>Avalanche</h2>
          <button class="toggle-btn" id="toggle-btn">
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
            >
              <path d="M3 12h18M3 6h18M3 18h18"></path>
            </svg>
          </button>
        </div>
        <p>User Control Panel</p>
      </div>

      <ul>
        <li>
          <button
            class="side-btn dashboard"
            onclick="location.href = '/userdash'"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="3" width="7" height="9"></rect>
              <rect x="14" y="3" width="7" height="5"></rect>
              <rect x="14" y="11" width="7" height="9"></rect>
              <rect x="3" y="15" width="7" height="5"></rect>
            </svg>
            <span class="side-btn-text">Dashboard</span>
          </button>
        </li>

        <li>
          <button class="side-btn orders" id="current">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path
                d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
              ></path>
            </svg>
            <span class="side-btn-text">Order History</span>
          </button>
        </li>
        <li>
          <button
            class="side-btn catalog"
            onclick="location.href = '/customercatalog'"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"
              ></path>
              <line x1="7" y1="7" x2="7.01" y2="7"></line>
            </svg>
            <span class="side-btn-text">Catalog</span>
          </button>
        </li>

        <li>
          <button
            class="side-btn appointments"
            onclick="location.href = '/scheduler'"
          >
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
            >
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span class="side-btn-text">Schedule</span>
          </button>
        </li>
      </ul>

      <div class="side-bottom">
        <hr />
        <button class="side-btn logout" onclick="location.href = '/logout'">
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            stroke="currentColor"
            stroke-width="2"
            fill="none"
          >
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          <span class="side-btn-text">Log Out</span>
        </button>
      </div>
    </aside>

    <main class="main-content">
      <div class="heading">
        <div class="heading-text">
          <h1>Order History</h1>
          <p>
            Track your celestial energy investments. View details for your solar
            installation, ongoing maintenance cycles, and system hardware
            upgrades.
          </p>
        </div>
        <div class="Investments">
          <h3>Total Investment</h3>
          <h2 id="total-investment">EGP 0.00</h2>
        </div>
      </div>

      <div class="filter-bar">
        <div class="righ-part">
          <div class="option" id="current-option" data-filter="all">
            All Orders
          </div>
          <div class="option" data-filter="hardware">Hardware</div>
          <div class="option" data-filter="maintenance">Maintenance</div>
        </div>
        <div class="left-part">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
            <path
              d="M96 128C83.1 128 71.4 135.8 66.4 147.8C61.4 159.8 64.2 173.5 73.4 182.6L256 365.3L256 480C256 488.5 259.4 496.6 265.4 502.6L329.4 566.6C338.6 575.8 352.3 578.5 364.3 573.5C376.3 568.5 384 556.9 384 544L384 365.3L566.6 182.7C575.8 173.5 578.5 159.8 573.5 147.8C568.5 135.8 556.9 128 544 128L96 128z"
            />
          </svg>
          <p>Sort by: Newest First</p>
        </div>
      </div>

      <div id="orders-container"></div>

      <div class="bottom-cards">
        <div class="expansion">
          <h3>Expand Your Solar System</h3>
          <p>
            Need more power? Upgrade your system to match your growing energy
            needs
          </p>
          <button class="expansion-btn">Contact Consultant</button>
        </div>

        <div class="support">
          <h3>Need help with an order?</h3>
          <p>
            Our support team is here to assist you with installation, billing,
            or technical issues.
          </p>
          <button class="support-btn">Talk to an expert</button>
        </div>
      </div>
    </main>

    <script src="/js/Customer_Order_History.js"></script>
  </body>
</html>
