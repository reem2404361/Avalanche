<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : "Avalanche | Appointment Confirmed" %></title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/confirmed.css">
</head>
<body>

<div class="wrapper">
    <span class="indicator-tag">Booking Processed</span>
    <h1>Appointment Confirmed</h1>
    <p class="subtitle">Your scheduled configuration request is logged into our dashboard</p>

    <div class="receipt-card">
        <p class="table-title">Booking Details</p>
        <table>
            <tr>
                <td class="label-cell">Reference ID</td>
                <td class="val-cell highlight-text"><%= appointmentId %></td>
            </tr>
            <tr>
                <td class="label-cell">Customer Name</td>
                <td class="val-cell"><%= bookingDetails.fullName %></td>
            </tr>
            <tr>
                <td class="label-cell">Email</td>
                <td class="val-cell"><%= bookingDetails.email %></td>
            </tr>
            <tr>
                <td class="label-cell">Phone</td>
                <td class="val-cell"><%= bookingDetails.phone %></td>
            </tr>
            <tr>
                <td class="label-cell">Address</td>
                <td class="val-cell"><%= bookingDetails.address %></td>
            </tr>
            <tr>
                <td class="label-cell">Location</td>
                <td class="val-cell"><%= bookingDetails.location %></td>
            </tr>
            <tr>
                <td class="label-cell">Date</td>
                <td class="val-cell"><%= bookingDetails.selectedDate || bookingDetails.date %></td>
            </tr>
            <tr>
                <td class="label-cell">Time Slot</td>
                <td class="val-cell highlight-text"><%= bookingDetails.timeSlot %></td>
            </tr>
            <tr>
                <td class="label-cell">Status</td>
                <td class="val-cell">
                    <span class="badge-pending">
                        <%= (typeof bookingDetails.status !== 'undefined' && bookingDetails.status) ? bookingDetails.status : "Pending" %>
                    </span>
                </td>
            </tr>
        </table>
    </div>

    <div class="btn-row">
        <a href="/userdash" class="action-btn">Go to Dashboard</a>
        <a href="/appointments/my" class="action-btn secondary">My Appointments</a>
    </div>
</div>

</body>
</html>