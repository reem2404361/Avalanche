<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : "Avalanche | Appointment Confirmed" %></title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #0A0800;
            --bg-card: linear-gradient(135deg, rgba(42,32,0,0.95) 0%, rgba(26,20,0,0.98) 100%);
            --border-accent: rgba(255,214,0,0.2);
            --gold-primary: #FFD600;
            --gold-light: #FFE680;
            --text-muted: rgba(255,230,128,0.55);
            --cursor-clr: rgba(255, 214, 0, 0.3);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: radial-gradient(ellipse 70% 55% at 12% 10%, rgba(255,198,0,0.15) 0%, transparent 65%),
                        linear-gradient(165deg, #1C1600 0%, var(--bg-main) 100%);
            font-family: 'Manrope', sans-serif;
            color: #FFF9E6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            overflow: hidden;
        }

        #cursor {
            width: 8px; height: 8px;
            background: var(--gold-primary);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 999999;
            transform: translate(-50%, -50%);
        }
        #cursor-ring {
            width: 32px; height: 32px;
            border: 2px solid var(--cursor-clr);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 999998;
            transform: translate(-50%, -50%);
            transition: width 0.2s, height 0.2s;
        }

        .sun-messenger {
            position: fixed;
            width: 75px; height: 75px;
            z-index: 100;
            top: 45%; right: -100px;
            transform: translateY(-50%);
            animation: sunFlight 1.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }
        @keyframes sunFlight {
            0%   { right: -100px; top: 50%; transform: translateY(-50%) rotate(0deg) scale(1.4); }
            50%  { right: 40%; top: 25%; transform: translateY(-50%) rotate(180deg) scale(1.2); }
            100% { right: calc(100% - 60px); top: 40px; transform: translateY(0) rotate(360deg) scale(1); }
        }

        .wrapper { width: 100%; max-width: 520px; position: relative; }
        .indicator-tag, h1, .subtitle, .receipt-card, .action-btn {
            opacity: 0; transform: translateY(20px);
            animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .indicator-tag  { animation-delay: 1.9s; margin-top: 50px; }
        h1              { animation-delay: 2.0s; }
        .subtitle       { animation-delay: 2.1s; }
        .receipt-card   { animation-delay: 2.2s; }
        .action-btn     { animation-delay: 2.3s; }
        @keyframes reveal { to { opacity: 1; transform: translateY(0); } }

        .indicator-tag {
            color: var(--gold-primary);
            font-size: 11px; letter-spacing: 0.16em;
            text-transform: uppercase; font-weight: 700;
            margin-bottom: 8px; display: block;
        }
        h1 {
            font-size: 34px; font-weight: 800;
            color: var(--gold-light); margin-bottom: 8px;
            letter-spacing: -0.02em;
        }
        .subtitle {
            font-size: 14px; color: var(--text-muted); margin-bottom: 32px;
        }

        .receipt-card {
            background: var(--bg-card);
            border: 0.5px solid var(--border-accent);
            border-radius: 16px; padding: 28px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.8);
        }
        .table-title {
            font-size: 10px; letter-spacing: 0.15em;
            text-transform: uppercase; color: rgba(255,198,0,0.45);
            margin-bottom: 16px; font-weight: 700;
        }
        table { width: 100%; border-collapse: collapse; font-size: 14px; }
        td { padding: 12px 0; vertical-align: middle; }
        .label-cell { color: rgba(255,198,0,0.45); width: 42%; }
        .val-cell { text-align: right; font-weight: 600; color: #FFF9E6; }
        .highlight-text { color: var(--gold-primary); font-weight: 700; }
        tr { border-bottom: 0.5px solid rgba(255,214,0,0.06); }
        tr:last-child { border: none; }

        .badge {
            background: rgba(46,204,113,0.15); color: #2ecc71;
            font-size: 10px; padding: 3px 10px; border-radius: 12px;
            margin-left: 6px; font-weight: 700;
            border: 0.5px solid rgba(46,204,113,0.3);
        }

        .btn-row { display: flex; gap: 12px; margin-top: 32px; flex-wrap: wrap; }
        .action-btn {
            display: inline-flex; align-items: center;
            padding: 14px 28px;
            background: linear-gradient(135deg, var(--gold-primary) 0%, #FF9800 100%);
            border: none; border-radius: 8px; font-weight: 700;
            color: #110E00; font-size: 14px; letter-spacing: 0.02em;
            box-shadow: 0 6px 22px rgba(255,198,0,0.25);
            transition: transform 0.2s ease; text-decoration: none;
        }
        .action-btn:hover { transform: translateY(-2px); }
        .action-btn.secondary {
            background: rgba(255,214,0,0.08);
            color: var(--gold-light);
            border: 1px solid rgba(255,214,0,0.25);
            box-shadow: none;
        }

        .falling-spark {
            position: fixed; pointer-events: none;
            font-size: var(--size); color: var(--color);
            z-index: 99999;
            animation: sparkFall var(--duration) linear forwards;
        }
        @keyframes sparkFall {
            0%   { transform: translate(0,0) scale(1.2); opacity: 1; }
            100% { transform: translate(var(--mx), var(--my)) scale(0.1); opacity: 0; }
        }
    </style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>

<img class="sun-messenger"
     src="/images/sun.png"
     alt="solar"
     onerror="this.src='https://cdn-icons-png.flaticon.com/512/869/869869.png'">

<div class="wrapper">
    <span class="indicator-tag">✦ Booking Verified &amp; Confirmed</span>
    <h1>Appointment Confirmed</h1>
    <p class="subtitle">Your installation audit has been scheduled. See you on site!</p>

    <div class="receipt-card">
        <p class="table-title">Booking Registry</p>
        <table>
            <tr>
                <td class="label-cell">Reference ID</td>
                <td class="val-cell highlight-text"><%= appointmentId %></td>
            </tr>
            <tr>
                <td class="label-cell">Customer Name</td>
                <td class="val-cell"><%= bookingDetails.fullName %></td>
            </tr>
            <tr>
                <td class="label-cell">Email</td>
                <td class="val-cell" style="color: var(--gold-light);"><%= bookingDetails.email %></td>
            </tr>
            <tr>
                <td class="label-cell">Phone</td>
                <td class="val-cell"><%= bookingDetails.phone %></td>
            </tr>
            <tr>
                <td class="label-cell">Date</td>
                <td class="val-cell"><%= bookingDetails.selectedDate %></td>
            </tr>
            <tr>
                <td class="label-cell">Time Slot</td>
                <td class="val-cell highlight-text"><%= bookingDetails.timeSlot %></td>
            </tr>
            <tr>
                <td class="label-cell">Status</td>
                <td class="val-cell"><span class="badge"><%= bookingDetails.status %></span></td>
            </tr>
        </table>
    </div>

    <div class="btn-row">
        <a href="/userdash" class="action-btn">Go to Dashboard</a>
        <a href="/appointments/my" class="action-btn secondary">My Appointments</a>
    </div>
</div>

<script>
    const cursor = document.getElementById("cursor");
    const ring   = document.getElementById("cursor-ring");
    const icons  = ['★','✦','✧','✶'];
    const colors = ['#FFD600','#FFE680','#FFF9C4','#FF9800'];
    let lastSpark = 0;

    document.addEventListener('mousemove', (e) => {
        if (cursor) { cursor.style.left = e.clientX + 'px'; cursor.style.top = e.clientY + 'px'; }
        if (ring)   { ring.style.left   = e.clientX + 'px'; ring.style.top   = e.clientY + 'px'; }

        const now = Date.now();
        if (now - lastSpark < 25) return;
        lastSpark = now;

        const spark = document.createElement('span');
        spark.className = 'falling-spark';
        spark.style.left = e.clientX + 'px';
        spark.style.top  = e.clientY + 'px';

        const size     = 7 + Math.random() * 11;
        const duration = 0.45 + Math.random() * 0.45;
        const mx       = (Math.random() - 0.5) * 45;
        const my       = 65 + Math.random() * 65;

        spark.style.setProperty('--size',     size + 'px');
        spark.style.setProperty('--duration', duration + 's');
        spark.style.setProperty('--color',    colors[Math.floor(Math.random() * colors.length)]);
        spark.style.setProperty('--mx',       mx + 'px');
        spark.style.setProperty('--my',       my + 'px');
        spark.textContent = icons[Math.floor(Math.random() * icons.length)];

        document.body.appendChild(spark);
        setTimeout(() => spark.remove(), duration * 1000);
    });
</script>
</body>
</html>
